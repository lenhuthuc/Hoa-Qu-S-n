# FastAPI Service — Environment Configuration
# Copy file này thành .env và điền các API keys

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🤖 AI & LLM API Keys (Bắt buộc)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Google Gemini API Key (Vision + Text LLM)
# Lấy từ: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq API Key (LLaMA 3.3 70B text generation)
# Lấy từ: https://console.groq.com
GROQ_API_KEY=

# OpenRouter API Key (Vision model fallback — tùy chọn)
# Lấy từ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cerebras API Key (tùy chọn — dự phòng)
CEREBRAS_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗄️ Database & Cache
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# MongoDB (Document Store)
MONGO_URL=mongodb://localhost:27017/hoaquason

# Redis (Cache & Session)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis123

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📡 Vector & Search
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Qdrant (Vector DB cho semantic search)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=products

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔗 Service URLs
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Spring Boot Backend (Java)
SPRING_SERVICE_URL=http://localhost:8080

# MinIO (S3-compatible Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hoaquason-ai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🧠 ML Models
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Embedding model cho semantic search
EMBEDDING_MODEL=intfloat/multilingual-e5-base
